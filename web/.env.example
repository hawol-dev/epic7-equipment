# 사이트 공개 URL (메타태그 / sitemap / og:url 용)
# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.vercel.app 또는 커스텀 도메인
NEXT_PUBLIC_SITE_URL=

# Vercel 자동 주입 환경변수 (참고용 — 직접 설정 X)
# VERCEL_ENV         production / preview / development
# VERCEL_URL         배포된 deployment URL
# VERCEL_GIT_COMMIT_SHA, VERCEL_GIT_COMMIT_REF 등
